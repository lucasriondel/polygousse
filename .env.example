# ──────────────────────────────────────────────
# Polygousse — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and uncomment/edit values as needed.

# ── Ports ────────────────────────────────────
# PORT=5616                   # API server port (default: 5616)
# VITE_PORT=5615              # Web dev server port (default: 5615)
# PTY_BRIDGE_PORT=5617        # PTY bridge WebSocket port (default: 5617)
# PTY_BRIDGE_HOST=127.0.0.1  # PTY bridge bind address (default: 127.0.0.1)
# PTY_BRIDGE_WEB_PORT=5615   # Web port used by PTY bridge for CORS (default: 5615)

# ── CORS ─────────────────────────────────────
# CORS_ORIGINS=http://localhost:5615,http://localhost:3000
#   Comma-separated list of allowed CORS origins for the API.
#   Defaults to http://localhost:5615 and tauri://localhost.
#
# PTY_BRIDGE_CORS_ORIGINS=http://localhost:5615
#   Additional CORS origins for the PTY bridge (comma-separated).

# ── Database ─────────────────────────────────
# POLYGOUSSE_DB_PATH=./data/polygousse.db
#   Path to the SQLite database file.
#   Set to ":memory:" for in-memory DB (used in tests).

# ── API URL (CLI & MCP server) ───────────────
# POLYGOUSSE_API_URL=http://localhost:5616/api
#   Base URL for the API, used by the CLI and MCP server.

# ── Debug Logging ────────────────────────────
# Set any of these to 1 to enable the corresponding debug channel.
# See apps/api/DEBUG.md for full details.
#
# POLYGOUSSE_DEBUG_ALL=0              # Enable ALL debug channels at once
# POLYGOUSSE_DEBUG_ORCHESTRATOR=0     # State machine transitions, hook wait/match/timeout
# POLYGOUSSE_DEBUG_SETTINGS=0         # Setting reads, upserts, and deletes
# POLYGOUSSE_DEBUG_TASK_LIFECYCLE=0   # Task creation, status transitions, tmux commands
# POLYGOUSSE_DEBUG_HOOKS=0            # Hook event processing pipeline
# POLYGOUSSE_DEBUG_WS=0               # WebSocket dispatch and broadcast

# ── File Logging ───────────────────────────────
# POLYGOUSSE_LOG_DIR=./logs                   # Directory for daily JSONL log files (polygousse-YYYY-MM-DD.log)
